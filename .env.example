# Copy to .env and fill in. Never commit .env.

# OAuth 2.0 (v2 API — services.leadconnectorhq.com)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_ACCESS_TOKEN=
GHL_REFRESH_TOKEN=
GHL_LOCATION_ID=
GHL_COMPANY_ID=

# Legacy v1 API key (rest.gohighlevel.com) — only if you need v1 endpoints
GHL_API_KEY=

# API version pin for v2 (header: Version)
GHL_API_VERSION=2021-07-28

# ---------------------------------------------------------------------------
# SQL Server connection (load_to_sql.py / refresh_daily.py / dashboard)
# ---------------------------------------------------------------------------
# Local Docker (default): localhost,1433
# Windows VM via Tailscale: <vm-tailnet-hostname>,1433
#   e.g. win-dcr.tail-XXXXX.ts.net,1433  or  100.x.y.z,1433
GHL_SQL_SERVER=localhost,1433
GHL_SQL_USER=sa
GHL_SQL_PASSWORD=GhlDev_PassW0rd!
GHL_SQL_DATABASE=dcr_warehouse

# ---------------------------------------------------------------------------
# Read-only login for the DCR MCP server (LLM-driven reads)
# ---------------------------------------------------------------------------
# Reuses GHL_SQL_SERVER / GHL_SQL_DATABASE above; only the credentials differ.
# Created by Phase 1 of the MCP build: db_datareader + DENY write/exec/alter.
MCP_SQL_USER=dcr_ro
MCP_SQL_PASSWORD=

# ---------------------------------------------------------------------------
# Failure alerts (refresh_daily.py — fires only on non-zero exit / crash)
# ---------------------------------------------------------------------------
# Slack or Discord incoming webhook. Leave blank to disable webhook alerts.
ALERT_WEBHOOK_URL=
# macOS banner: 1/true/yes to force, 0 to disable. Defaults on under macOS.
ALERT_MACOS=
